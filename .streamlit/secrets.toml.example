# .streamlit/secrets.toml
# This file is used by Streamlit Cloud for secret management.
# Fill in your actual keys when deploying to Streamlit Cloud.
# DO NOT commit this file with real keys to GitHub!

OPENROUTER_API_KEY = "your-openrouter-api-key-here"
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your-supabase-anon-key-here"
